# A&J Real Estate Group — environment variables
# Copy to .env.local and fill in real values (never commit .env.local).

# Supabase — ITMANO CRM project (public read of published listings).
# Anon key only; the web never uses the service-role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Contact form -> ITMANO CRM contact webhook (server-to-server)
# Channel public_id for the "Contact Us" form.
NEXT_PUBLIC_ITMANO_CONTACT_PUBLIC_ID=chn_qv8uhxg9qizl
# Shared secret for the x-contact-secret header. NEVER commit the real value —
# set it in .env.local and in the Vercel project env vars.
CONTACT_WEBHOOK_SECRET=
